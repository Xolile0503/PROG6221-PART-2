<Window x:Class="CybersecurityChatbotWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🛡️ Cybersecurity Assistant - Your Digital Security Companion"
        Height="750" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A2E">

    <Window.Resources>
        <!-- Styles -->
        <Style x:Key="CustomButton" TargetType="Button">
            <Setter Property="Background" Value="#0F3460"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1A4A7A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SendButton" TargetType="Button">
            <Setter Property="Background" Value="#00FF00"/>
            <Setter Property="Foreground" Value="#1A1A2E"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#33FF33"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ASCII Art Banner -->
        <Border Grid.Row="0" Background="#0F3460" CornerRadius="5" Margin="0,0,0,10" Padding="10">
            <TextBlock Text="╔══════════════════════════════════════════════════════════════╗&#xD;&#xA;║                     🛡️  CYBERSECURITY  🛡️                    ║&#xD;&#xA;║                     DIGITAL DEFENDER                         ║&#xD;&#xA;║                  &quot;Stay Safe, Stay Secure&quot;                    ║&#xD;&#xA;╚══════════════════════════════════════════════════════════════╝"
                       FontFamily="Courier New" FontSize="10" FontWeight="Bold"
                       Foreground="#00FF00" TextAlignment="Center"/>
        </Border>

        <!-- Chat Display Area -->
        <Border Grid.Row="1" Background="#0F3460" CornerRadius="5" Padding="5">
            <ScrollViewer x:Name="chatScrollViewer" VerticalScrollBarVisibility="Auto">
                <RichTextBox x:Name="chatDisplay" IsReadOnly="True" 
                             Background="#0F3460" Foreground="#E0E0E0"
                             FontFamily="Segoe UI" FontSize="11"
                             BorderThickness="0">
                    <RichTextBox.Resources>
                        <Style TargetType="{x:Type Paragraph}">
                            <Setter Property="Margin" Value="0"/>
                        </Style>
                    </RichTextBox.Resources>
                </RichTextBox>
            </ScrollViewer>
        </Border>

        <!-- Input Area -->
        <Border Grid.Row="2" Background="#1A1A2E" CornerRadius="5" Margin="0,10,0,0" Padding="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="inputTextBox" Grid.Column="0" 
                         TextWrapping="Wrap" AcceptsReturn="True"
                         Background="#16213E" Foreground="#E0E0E0"
                         BorderBrush="#0F3460" BorderThickness="1"
                         FontFamily="Segoe UI" FontSize="11"
                         MinHeight="60" MaxHeight="100"
                         VerticalScrollBarVisibility="Auto"
                         KeyDown="InputTextBox_KeyDown"/>

                <Button x:Name="sendButton" Grid.Column="1" 
                        Content="📤 Send" Style="{StaticResource SendButton}"
                        Width="80" Height="40" Margin="5,0,0,0"
                        Click="SendButton_Click" VerticalAlignment="Bottom"/>

                <Button x:Name="voiceButton" Grid.Column="2" 
                        Content="🎤 Voice" Style="{StaticResource CustomButton}"
                        Width="80" Height="40" Margin="5,0,0,0"
                        Click="VoiceButton_Click" VerticalAlignment="Bottom"/>
            </Grid>
        </Border>

        <!-- Task Buttons Area -->
        <Border Grid.Row="3" Background="#1A1A2E" CornerRadius="5" Margin="0,10,0,0" Padding="5">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="addTaskButton" Content="📝 Add Task" Style="{StaticResource CustomButton}"
                        Click="AddTaskButton_Click" Width="100"/>
                <Button x:Name="viewTasksButton" Content="📋 View Tasks" Style="{StaticResource CustomButton}"
                        Click="ViewTasksButton_Click" Width="100"/>
                <Button x:Name="completeTaskButton" Content="✅ Complete Task" Style="{StaticResource CustomButton}"
                        Click="CompleteTaskButton_Click" Width="100"/>
                <Button x:Name="deleteTaskButton" Content="🗑️ Delete Task" Style="{StaticResource CustomButton}"
                        Click="DeleteTaskButton_Click" Width="100"/>
                <Button x:Name="tipButton" Content="💡 Security Tip" Style="{StaticResource CustomButton}"
                        Click="TipButton_Click" Width="100"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
